# ==========================================
# JARVIS AI CONFIGURATION TEMPLATE
# ==========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ==========================================
# LOCAL LLM CONFIGURATION (REQUIRED)
# ==========================================
# Ollama must be running locally
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
FALLBACK_MODEL=llama3.1:8b-instruct

# ==========================================
# SPEECH-TO-TEXT (STT) CONFIGURATION
# ==========================================
# Options: tiny, base, small, medium, large
# tiny = fastest, medium quality (default)
# base = faster, better quality
# small = moderate speed, good quality
WHISPER_MODEL=tiny

# ==========================================
# TEXT-TO-SPEECH (TTS) CONFIGURATION
# ==========================================
# Default voice (only pyttsx3 is working locally)
TTS_VOICE=ur_urdu

# ==========================================
# CLOUD API KEYS (OPTIONAL)
# ==========================================
# Leave empty if you only want to use local models

# OpenAI or OpenRouter API Key
# Get from: https://platform.openai.com/api-keys
# Or: https://openrouter.ai/keys
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# For OpenRouter, use:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ElevenLabs API Key for cloud voice synthesis
# Get from: https://www.elevenlabs.io/api
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ==========================================
# SECURITY & CONNECTION
# ==========================================
JARVIS_AUTH_TOKEN=change_this_to_random_token
PORT=8080
HOST=0.0.0.0
DEBUG=False

# ==========================================
# WAKE WORDS & COMMANDS
# ==========================================
WAKE_PHRASE=Jarvis, let's start
STOP_PHRASE=Jarvis stop
KILL_HOTKEY=ctrl+shift+k

# ==========================================
# SYSTEM SETTINGS
# ==========================================
LOG_LEVEL=INFO
SESSION_TIMEOUT=300
CONTEXT_LIMIT=5
MAX_HISTORY=100
