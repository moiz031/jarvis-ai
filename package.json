{
  "name": "jarvis-ai",
  "version": "1.0.0",
  "description": "Jarvis AI Desktop Application",
  "main": "main.js",
  "author": "Michael Carter",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "lint": "npx eslint . --ext .js --quiet || echo 'Lint complete (or ESLint not configured)'",
    "test": "node scripts/python-runner.cjs -m pytest tests -q --tb=short",
    "build:backend": "node scripts/python-runner.cjs build_backend.py",
    "build": "npx --no-install electron-builder --win --x64",
    "dist": "npm run build:backend && npx --no-install electron-builder --win --x64"
  },
  "build": {
    "appId": "com.jarvis.ai",
    "productName": "Jarvis AI",
    "electronVersion": "40.3.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "backend/JarvisBackend.exe",
        "to": "backend/JarvisBackend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jarvis AI",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "asar": true
  },
  "devDependencies": {
    "electron": "40.3.0",
    "electron-builder": "^24.13.3"
  }
}
